# ResearchOps — HuggingFace Spaces Secrets reference
#
# This file is a template ONLY. Do NOT commit a populated copy with real keys.
# Real values must be configured in the HF Space UI:
#   Settings -> Variables and secrets -> "New secret"
#
# The defaults in the Dockerfile (LLM_BACKEND=none) keep the Space working
# end-to-end without any keys. Setting any of the variables below upgrades the
# pipeline to a real LLM at runtime.

# ───── LLM backend selector ────────────────────────────────────────────────
# Default: none (rule-based agents — deterministic skeleton report).
# Switch to openai_compat / openai / anthropic to enable a real LLM.
# LLM_BACKEND=openai_compat

# Model name. Optional; sensible defaults are baked in per backend.
# LLM_MODEL=deepseek-chat
# LLM_MODEL=gpt-4o-mini
# LLM_MODEL=claude-sonnet-4-20250514

# Base URL — REQUIRED when using openai_compat with a non-OpenAI provider.
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_BASE_URL=https://openrouter.ai/api/v1

# ───── Provider keys (set ONE matching your backend) ───────────────────────
# DEEPSEEK_API_KEY=sk-...
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# LLM_API_KEY=...   # generic fallback if your provider isn't listed above

# ───── Langfuse observability (optional) ───────────────────────────────────
# When all three are set, every run is mirrored into your Langfuse project.
# Cloud:        https://cloud.langfuse.com   (US: https://us.cloud.langfuse.com)
# Self-host:    http://your-host:3000
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_HOST=https://cloud.langfuse.com

# ───── Gradio / runtime knobs (rarely changed) ─────────────────────────────
# HOST=0.0.0.0
# PORT=7860
# GRADIO_ANALYTICS_ENABLED=False
