# ResearchOps Agent — Environment Variables
# Copy this file to .env and fill in the values you need.

# ---- LLM Configuration ----
# Backend: none | openai_compat | anthropic
# LLM_BACKEND=openai_compat

# Model name (e.g. deepseek-chat, gpt-4o, claude-sonnet-4-20250514)
# LLM_MODEL=deepseek-chat

# API base URL (required for openai_compat)
# LLM_BASE_URL=https://api.deepseek.com/v1

# API keys — set the one matching your provider
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# DEEPSEEK_API_KEY=
# LLM_API_KEY=
