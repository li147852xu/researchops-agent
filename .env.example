# ResearchOps — Environment Variables
# Copy this file to .env and fill in the values you need.

# ---- LLM Configuration ----
# Backend: openai_compat | openai | anthropic | none
# LLM_BACKEND=openai_compat

# Model name (e.g. deepseek-chat, gpt-4o-mini, claude-sonnet-4-20250514)
# LLM_MODEL=gpt-4o-mini

# API base URL (required for openai_compat with non-OpenAI providers)
# LLM_BASE_URL=https://api.openai.com/v1

# API keys — set the one matching your provider
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# DEEPSEEK_API_KEY=
# LLM_API_KEY=

# ---- Web UI ----
# WEB_HOST=0.0.0.0
# WEB_PORT=7860

# ---- FastAPI ----
# API_HOST=0.0.0.0
# API_PORT=8000
